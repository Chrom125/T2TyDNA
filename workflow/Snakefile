samples, = glob_wildcards("ressources/data/{sample}/{sample}.fastq.gz")

rule all:
    input:
        #expand("results/{sample}_mapped.sam", sample=samples),
        #"results/Filtred_Results.csv"
        #expand("results/{sample}/{sample}_tel_len.png", sample = samples),
        #expand("results/{sample}/{sample}_filtered.fastq", sample=samples),
        "results/common/tel_len.png"


rule filtlong:
    input:
        "ressources/data/{sample}/{sample}.fastq.gz"
    output:
        "results/{sample}/{sample}_filtered.fastq"
    params:
        results_directory = "results/{sample}"
    conda:
        "t2tydna"
    log:
        "results/{sample}/logs/{sample}_filtlong.log"
    shell:
        """
        mkdir -p {params.results_directory}
        filtlong --min_length 1000 --keep_percent 90 --target_bases 500000000 {input} > {output} 2>{log}
        """

rule assembly:
    input:
        "results/{sample}/{sample}_filtered.fastq"
    output:
        "results/{sample}/{sample}_genome.fa"
    conda:
        "t2tydna"
    log:
        "results/{sample}/logs/{sample}_assembly.log"
    threads: 32
    shadow: "minimal"
    shell:
        """
        flye --nano-hq {input} --genome-size 12.5m --threads {threads} -i 2 --out-dir results/flye_tmp 2>{log}
        cp results/flye_tmp/assembly.fasta {output}
        """

#
# Nicolo's pipeline
#
rule mapping_all:
    input:
        reads = "results/{sample}/{sample}_filtered.fastq",
        assembly = "results/{sample}/{sample}_genome.fa"
    output:
        "results/{sample}/{sample}_mapped.sam"
    conda:
        "t2tydna"
    log:
        "results/{sample}/logs/{sample}_assembly.log"
    threads: 8
    shell:
        "minimap2 -ax map-ont -t {threads} {input.assembly} {input.reads} > {output} 2>{log}"

rule snv_counter:
    input:
        assembly = expand("results/{sample}/{sample}_genome.fa", sample = samples),
        mapping = expand("results/{sample}/{sample}_mapped.sam", sample = samples)
    output:
        "{sample}_snv_table.csv"
    log:
        "results/{sample}/logs/{sample}_snv_count.log"
    
    

#
# Clothilde's pipeline
#

rule file_preparation_for_telomere_script:
    input:
        reads = "results/{sample}/{sample}_filtered.fastq",
        assembly = "results/{sample}/{sample}_genome.fa"
    output:
        "results/{sample}/{sample}_data_position_table.tsv"
    conda:
        "telofinder"
    log:
        "results/{sample}/logs/{sample}_file_preparation.log"
    script:
        "scr/file_preparation_telomere.py"
    
rule telomere_length:
    input:
        table = "results/{sample}/{sample}_data_position_table.tsv",
        reads = "results/{sample}/{sample}_filtered.fastq"
    output:
        "results/{sample}/{sample}_Filtred_Results.csv"
    conda:
        "telofinder"
    log:
        "results/{sample}/logs/{sample}_telomere_length.log"
    threads:
        8
    shell:
        """
        python workflow/scr/get_telomere_length.py --input_data {input.table} --output_dir results/{wildcards.sample}/ --threads {threads} --intern_min_length 100 --only_trim
        mv results/{wildcards.sample}/Filtred_Results.csv {output}
        """

rule plot_telomere_length:
    input:
        expand("results/{sample}/{sample}_Filtred_Results.csv", sample = samples)
    output:
        "results/common/tel_len.png"
    conda:
        "telofinder"
    log:
        "results/common/logs/plotting_telomere_length.log"
    script:
        "scr/telomere_view_results.py"
